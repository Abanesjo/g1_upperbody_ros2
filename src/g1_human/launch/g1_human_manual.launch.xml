<launch>
  <node pkg="g1_human" exec="g1_human_node" name="g1_human_node" output="screen">
    <param from="$(find-pkg-share g1_human)/config/human.yaml"/>
  </node>

  <!-- Joint GUI remapped to human commands -->
  <node pkg="g1_rl_deploy" exec="joint_command_gui" name="human_joint_gui" output="screen">
    <remap from="/joint_commands" to="/human/joint_commands"/>
  </node>
</launch>
